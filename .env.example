# =============================================================================
# CloudLab Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,cloudlab.yourdomain.com
DJANGO_SETTINGS_MODULE=cloudlab.settings.development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cloudlab:cloudlab@postgres:5432/cloudlab

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AWS (S3 / Media) ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=cloudlab-media
AWS_S3_REGION_NAME=ap-south-1
USE_S3=False

# ── Social Auth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Docker Lab Provisioning ───────────────────────────────────────────────────
# Linux/Mac: unix:///var/run/docker.sock
# Windows Docker Desktop: npipe:////./pipe/docker_engine
DOCKER_HOST=unix:///var/run/docker.sock
MAX_CONTAINERS_PER_USER=2
LAB_CONTAINER_MEMORY_LIMIT=512m
LAB_CONTAINER_CPU_QUOTA=50000
LAB_CONTAINER_CPU_PERIOD=100000

# ── Kubernetes Labs ───────────────────────────────────────────────────────────
K8S_ENABLED=False
K8S_NAMESPACE=cloudlab-labs
KUBECONFIG=/etc/kubernetes/admin.conf

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@cloudlab.yourdomain.com

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Stripe (Billing — Phase 3) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend (Vite env vars) ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
VITE_STRIPE_PUBLISHABLE_KEY=
